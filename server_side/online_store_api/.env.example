# Server
PORT=3000
MONGO_URL=your_mongodb_connection_string
JWT_SECRET=your_long_random_secret
NODE_ENV=development

# OneSignal
ONE_SIGNAL_APP_ID=your_onesignal_app_id
ONE_SIGNAL_REST_API_KEY=your_onesignal_rest_key

# Email OTP delivery (Gmail SMTP). For Gmail, EMAIL_PASS must be an App Password
# (Google Account -> Security -> 2-Step Verification -> App passwords), NOT your
# normal account password.
EMAIL_FROM=noreply@quickgo.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail_address
EMAIL_PASS=your_gmail_app_password

# Google "Sign in with Google" — verify ID tokens against these client IDs.
# Set the ones you use (web for Flutter web/admin, android/ios for mobile builds).
GOOGLE_CLIENT_ID=your_primary_oauth_client_id
GOOGLE_CLIENT_ID_WEB=your_web_oauth_client_id
GOOGLE_CLIENT_ID_ANDROID=your_android_oauth_client_id
GOOGLE_CLIENT_ID_IOS=your_ios_oauth_client_id

# Phone normalization (phone is now an optional profile field only)
DEFAULT_COUNTRY_CODE=+91

# Payment (placeholders)
STRIPE_PBLK_KET_TST=STRIPE_PUBLISH_KEY
STRIPE_SKRT_KET_TST=STRIPE_SECRET_KEY
RAZORPAY_KEY_TEST=RAZOR_PAY_KEY
